PROJECT_NAME=PurpleForge
API_V1_STR=/api/v1

# Use values relative to docker services if running via compose
DATABASE_URL=postgresql://postgres:postgres@db:5432/purpleforge
REDIS_URL=redis://redis:6379/0

# For local dev outside of docker, uncomment:
